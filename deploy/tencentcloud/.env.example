# 临时测试时可改为 8080，正式替换主站时可用 80。
WEB_PORT=80

# 如需避开本机已有服务，可指定绑定公网 IP，而不是 0.0.0.0。
WEB_BIND_HOST=0.0.0.0

# 如需挂到主站子路径，例如 /judgewrite/，请填写对应前缀。
VITE_BASE_PATH=/

# 如果前端和 API 走同域反向代理，可留空。
VITE_API_BASE_URL=

# 生产环境请改成你的前端域名，多个域名用逗号分隔。
JUDGEWRITE_CORS_ORIGINS=https://pawtrip.pet,http://pawtrip.pet

# 如需接入 pawtrip 主站的 Caddy 网络，保持默认即可。
PAWTRIP_GATEWAY_NETWORK=pawtripserver_default

# 如需接入真实模型，请填写。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
